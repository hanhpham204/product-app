<!DOCTYPE html>
<html>
<head>
  <title>Products</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-4">
  <h3>Product List</h3>

  <a href="/create" class="btn btn-primary btn-sm mb-3">Add</a>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Image</th>
        <th>Name</th>
        <th>Price</th>
        <th>Stock</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% products.forEach(p => { %>
        <tr>
          <td><img src="<%= p.url_image %>" width="60"></td>
          <td><%= p.name %></td>
          <td><%= p.price %></td>
          <td><%= p.unit_in_stock %></td>
          <td>
            <a href="/detail/<%= p.id %>" class="btn btn-sm btn-secondary">View</a>
            <a href="/edit/<%= p.id %>" class="btn btn-sm btn-warning">Edit</a>
            <a href="/delete/<%= p.id %>" class="btn btn-sm btn-danger"
               onclick="return confirm('Delete?')">Delete</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>