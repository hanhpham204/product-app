<!DOCTYPE html>
<html>
<head>
  <title>Edit</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-4">
  <h3>Edit Product</h3>

  <form method="POST" enctype="multipart/form-data">
    <input type="hidden" name="old_image" value="<%= product.url_image %>">

    <div class="mb-2">
      <input name="name" value="<%= product.name %>" class="form-control">
    </div>

    <div class="mb-2">
      <input name="price" value="<%= product.price %>" class="form-control">
    </div>

    <div class="mb-2">
      <input name="unit_in_stock" value="<%= product.unit_in_stock %>" class="form-control">
    </div>

    <div class="mb-2">
      <input type="file" name="image" class="form-control">
    </div>

    <button class="btn btn-warning btn-sm">Update</button>
    <a href="/" class="btn btn-secondary btn-sm">Back</a>
  </form>
</div>

</body>
</html>